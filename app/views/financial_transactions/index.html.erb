<% content_for :title, "Financeiro" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Financeiro</h1>
  <div class="flex items-center gap-3">
    <%= link_to new_financial_transaction_path(type: "income"), class: "flex items-center gap-2 px-3 py-2 text-sm text-green-700 bg-green-50 border border-green-200 hover:bg-green-100 rounded-lg transition-colors" do %>
      + Receita
    <% end %>
    <%= link_to new_financial_transaction_path(type: "expense"), class: "flex items-center gap-2 px-3 py-2 text-sm text-red-700 bg-red-50 border border-red-200 hover:bg-red-100 rounded-lg transition-colors" do %>
      + Despesa
    <% end %>
  </div>
</div>

<!-- KPI row -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Receitas (mês)</p>
    <p class="text-2xl font-bold text-green-600">R$ <%= number_with_precision(@total_income, precision: 2) %></p>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Despesas (mês)</p>
    <p class="text-2xl font-bold text-red-600">R$ <%= number_with_precision(@total_expense, precision: 2) %></p>
  </div>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Saldo</p>
    <p class="text-2xl font-bold <%= @balance >= 0 ? "text-green-600" : "text-red-600" %>">
      R$ <%= number_with_precision(@balance, precision: 2) %>
    </p>
  </div>
</div>

<!-- Filters -->
<div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 mb-6">
  <%= form_with url: financial_transactions_path, method: :get, class: "flex flex-wrap gap-3" do |f| %>
    <div>
      <%= f.select :type, options_for_select([["Todos", ""], ["Receitas", "income"], ["Despesas", "expense"]], params[:type]),
          {},
          class: "px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <div>
      <%= f.select :status, options_for_select([["Todos", ""], ["Pendente", "pending"], ["Pago", "paid"]], params[:status]),
          {},
          class: "px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    <%= f.submit "Filtrar", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg cursor-pointer" %>
  <% end %>
</div>

<!-- Transactions table -->
<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
  <% if @transactions.empty? %>
    <div class="p-12 text-center text-gray-500 dark:text-gray-400">
      <p>Nenhum lançamento encontrado</p>
    </div>
  <% else %>
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-700/50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Descrição</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase hidden sm:table-cell">Categoria</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Vencimento</th>
          <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Valor</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Status</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @transactions.each do |transaction| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full flex-shrink-0 <%= transaction.income? ? "bg-green-500" : "bg-red-500" %>"></div>
                <div>
                  <p class="text-sm font-medium text-gray-900 dark:text-white"><%= transaction.description %></p>
                  <p class="text-xs text-gray-500 dark:text-gray-400"><%= transaction.customer&.name || transaction.supplier&.name %></p>
                </div>
              </div>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300 hidden sm:table-cell">
              <% if transaction.category.present? %>
                <%= I18n.t("financial_categories.#{transaction.category}", default: transaction.category.humanize) %>
              <% else %>
                -
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm <%= transaction.overdue? ? "text-red-600 font-medium" : "text-gray-600 dark:text-gray-300" %>">
              <%= transaction.due_date&.strftime("%d/%m/%Y") || "-" %>
              <%= " (atrasado)" if transaction.overdue? %>
            </td>
            <td class="px-4 py-3 text-right text-sm font-semibold <%= transaction.income? ? "text-green-600" : "text-red-600" %>">
              <%= transaction.income? ? "+" : "-" %> R$ <%= number_with_precision(transaction.amount, precision: 2) %>
            </td>
            <td class="px-4 py-3 text-center">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= financial_status_badge(transaction.status) %>">
                <%= I18n.t("sale_statuses.#{transaction.status}", default: transaction.status.humanize) %>
              </span>
            </td>
            <td class="px-4 py-3 text-center">
              <div class="flex items-center justify-center gap-1">
                <% if transaction.pending? && policy(transaction).pay? %>
                  <%= button_to pay_financial_transaction_path(transaction), method: :patch,
                      class: "p-1.5 text-gray-400 hover:text-green-600 rounded transition-colors",
                      title: "Dar Baixa",
                      data: { turbo_confirm: "Confirmar baixa de R$ #{number_with_precision(transaction.amount, precision: 2)}?" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  <% end %>
                <% end %>
                <%= link_to edit_financial_transaction_path(transaction), class: "p-1.5 text-gray-400 hover:text-yellow-600 rounded transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="px-4 py-3 border-t border-gray-200 dark:border-gray-700">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
