<% content_for :title, "Movimentações de Estoque" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Movimentações de Estoque</h1>
  <%= link_to new_stock_movement_path, class: "flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Registrar Movimentação
  <% end %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
  <% if @movements.empty? %>
    <p class="p-8 text-center text-gray-500 dark:text-gray-400">Nenhuma movimentação encontrada.</p>
  <% else %>
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-700/50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Data</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Produto</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Tipo</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Qtd</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Estoque</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase hidden md:table-cell">Motivo</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase hidden sm:table-cell">Usuário</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @movements.each do |m| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">
              <%= m.created_at.strftime("%d/%m/%y %H:%M") %>
            </td>
            <td class="px-4 py-3">
              <p class="text-sm font-medium text-gray-900 dark:text-white"><%= m.product.name %></p>
              <p class="text-xs text-gray-500 font-mono"><%= m.product.internal_code %></p>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= m.entry? ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800" %>">
                <%= m.movement_type_label %>
              </span>
            </td>
            <td class="px-4 py-3 text-center text-sm font-semibold <%= m.quantity > 0 ? "text-green-600" : "text-red-600" %>">
              <%= m.quantity > 0 ? "+#{m.quantity}" : m.quantity %>
            </td>
            <td class="px-4 py-3 text-center text-sm font-mono text-gray-900 dark:text-white">
              <%= m.current_stock %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300 hidden md:table-cell">
              <%= m.reason || "-" %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300 hidden sm:table-cell">
              <%= m.user.name %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="px-4 py-3 border-t border-gray-200 dark:border-gray-700">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
