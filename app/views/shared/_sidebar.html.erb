<div class="hidden lg:fixed lg:inset-y-0 lg:flex lg:w-64 lg:flex-col" id="sidebar">
  <div class="flex flex-col flex-grow bg-slate-900 pt-5 pb-4 overflow-y-auto">
    <!-- Logo -->
    <div class="flex items-center flex-shrink-0 px-4 mb-6">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-blue-500 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
        </div>
        <div>
          <p class="text-white font-semibold text-sm leading-tight"><%= current_company&.name || "AutoPeças" %></p>
          <p class="text-slate-400 text-xs">ERP Sistema</p>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-2 space-y-1">
      <%= render "shared/nav_item", icon: "home", label: "Dashboard", path: root_path %>

      <div class="pt-3">
        <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Vendas</p>
        <div class="mt-1 space-y-1">
          <%= render "shared/nav_item", icon: "shopping_cart", label: "Vendas", path: sales_path %>
          <%= render "shared/nav_item", icon: "document_text", label: "Orçamentos", path: sales_path(sale_type: "quote") %>
        </div>
      </div>

      <div class="pt-3">
        <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Estoque</p>
        <div class="mt-1 space-y-1">
          <%= render "shared/nav_item", icon: "cube", label: "Produtos", path: products_path %>
          <%= render "shared/nav_item", icon: "tag", label: "Categorias", path: categories_path %>
          <%= render "shared/nav_item", icon: "arrows_right_left", label: "Movimentações", path: stock_movements_path %>
        </div>
      </div>

      <div class="pt-3">
        <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Cadastros</p>
        <div class="mt-1 space-y-1">
          <%= render "shared/nav_item", icon: "users", label: "Clientes", path: customers_path %>
          <%= render "shared/nav_item", icon: "truck", label: "Fornecedores", path: suppliers_path %>
        </div>
      </div>

      <div class="pt-3">
        <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Financeiro</p>
        <div class="mt-1 space-y-1">
          <%= render "shared/nav_item", icon: "banknotes", label: "Lançamentos", path: financial_transactions_path %>
          <%= render "shared/nav_item", icon: "arrow_trending_up", label: "A Receber", path: financial_transactions_path(type: "income") %>
          <%= render "shared/nav_item", icon: "arrow_trending_down", label: "A Pagar", path: financial_transactions_path(type: "expense") %>
        </div>
      </div>

      <% if current_user.admin? %>
        <div class="pt-3">
          <p class="px-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Configurações</p>
          <div class="mt-1 space-y-1">
            <%= render "shared/nav_item", icon: "users_cog", label: "Usuários", path: users_path %>
            <%= render "shared/nav_item", icon: "building_office", label: "Empresa", path: settings_company_path %>
          </div>
        </div>
      <% end %>
    </nav>

    <!-- User info at bottom -->
    <div class="flex-shrink-0 flex border-t border-slate-700 p-4">
      <div class="flex items-center gap-3 w-full">
        <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm font-semibold flex-shrink-0">
          <%= current_user.name.first.upcase %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white truncate"><%= current_user.name %></p>
          <p class="text-xs text-slate-400 truncate"><%= t("roles.#{current_user.role}") %></p>
        </div>
        <%= link_to destroy_user_session_path, method: :delete, data: { turbo_method: :delete }, class: "text-slate-400 hover:text-white" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Mobile sidebar toggle -->
<div class="lg:hidden fixed bottom-4 right-4 z-50">
  <button data-action="click->app#toggleSidebar" class="bg-blue-600 text-white rounded-full p-3 shadow-lg">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>
</div>
