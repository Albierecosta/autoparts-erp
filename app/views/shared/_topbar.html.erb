<div class="sticky top-0 z-10 flex-shrink-0 flex h-14 bg-white dark:bg-gray-800 shadow border-b border-gray-200 dark:border-gray-700">
  <div class="flex-1 px-4 flex justify-between items-center">
    <!-- Search bar -->
    <div class="flex-1 flex max-w-lg" data-controller="product-search">
      <div class="relative w-full">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
          </svg>
        </div>
        <input
          type="text"
          placeholder="Buscar produto por nome, código, marca ou veículo..."
          class="block w-full pl-9 pr-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          data-product-search-target="input"
          data-action="input->product-search#search keydown->product-search#navigate"
        >
        <div class="absolute top-full left-0 right-0 mt-1 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 z-50 hidden"
             data-product-search-target="results">
        </div>
      </div>
    </div>

    <!-- Right actions -->
    <div class="ml-4 flex items-center gap-3">
      <!-- New sale quick button -->
      <%= link_to new_sale_path, class: "hidden sm:flex items-center gap-2 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nova Venda
      <% end %>

      <!-- Alerts bell -->
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle" class="relative p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <% low_stock_count = current_company.products.active.low_stock.count rescue 0 %>
          <% if low_stock_count > 0 %>
            <span class="absolute top-1 right-1 block w-2 h-2 rounded-full bg-red-500"></span>
          <% end %>
        </button>
        <div class="hidden absolute right-0 mt-2 w-72 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 z-50"
             data-dropdown-target="menu">
          <div class="p-3 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Alertas de Estoque</h3>
          </div>
          <div class="p-2 max-h-64 overflow-y-auto">
            <% if low_stock_count > 0 %>
              <p class="text-sm text-orange-600 dark:text-orange-400 p-2">
                <span class="font-semibold"><%= low_stock_count %></span> produto(s) com estoque baixo
              </p>
              <%= link_to "Ver produtos", products_path(low_stock: "true"), class: "block text-center text-sm text-blue-600 hover:text-blue-700 p-2" %>
            <% else %>
              <p class="text-sm text-gray-500 p-2 text-center">Nenhum alerta no momento</p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Dark mode toggle -->
      <button data-action="click->app#toggleDarkMode" class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" title="Alternar tema">
        <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </button>
    </div>
  </div>
</div>
