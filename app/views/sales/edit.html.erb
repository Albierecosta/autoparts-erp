<% content_for :title, "Editar Venda ##{@sale.number}" %>
<div class="mb-4">
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
    <%= link_to "Vendas", sales_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %><span>/</span>
    <%= link_to "##{@sale.number}", sale_path(@sale), class: "hover:text-gray-700 dark:hover:text-gray-200" %><span>/</span>
    <span class="text-gray-900 dark:text-white">Editar</span>
  </nav>
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Editar Venda #<%= @sale.number %></h1>
</div>
<%= render "form", sale: @sale %>
