<% content_for :title, "Venda ##{@sale.number}" %>

<div class="mb-6 flex items-start justify-between">
  <div>
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
      <%= link_to "Vendas", sales_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %>
      <span>/</span>
      <span class="text-gray-900 dark:text-white">#<%= @sale.number %></span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
      <%= @sale.quote? ? "Orçamento" : "Venda" %> #<%= @sale.number %>
    </h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= @sale.created_at.strftime("%d/%m/%Y às %H:%M") %></p>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to receipt_sale_path(@sale), target: "_blank", class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
      </svg>
      Imprimir
    <% end %>
    <% if @sale.pending? %>
      <%= button_to confirm_sale_path(@sale), method: :patch,
          class: "flex items-center gap-2 px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-lg transition-colors",
          data: { turbo_confirm: "Confirmar esta venda? O estoque será descontado." } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Confirmar Venda
      <% end %>
    <% end %>
    <% if !@sale.cancelled? %>
      <%= link_to edit_sale_path(@sale), class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 transition-colors" do %>
        Editar
      <% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Items -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="font-semibold text-gray-900 dark:text-white">Itens</h2>
      </div>
      <table class="min-w-full">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Produto</th>
            <th class="px-5 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Qtd</th>
            <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Unitário</th>
            <th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          <% @sale.sale_items.each do |item| %>
            <tr>
              <td class="px-5 py-3">
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= item.product_name %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400 font-mono"><%= item.product_code %></p>
              </td>
              <td class="px-5 py-3 text-center text-sm text-gray-600 dark:text-gray-300"><%= item.quantity %></td>
              <td class="px-5 py-3 text-right text-sm text-gray-600 dark:text-gray-300">R$ <%= number_with_precision(item.unit_price, precision: 2) %></td>
              <td class="px-5 py-3 text-right text-sm font-semibold text-gray-900 dark:text-white">R$ <%= number_with_precision(item.total, precision: 2) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="border-t-2 border-gray-200 dark:border-gray-600">
          <tr>
            <td colspan="3" class="px-5 py-3 text-right text-sm text-gray-500 dark:text-gray-400">Subtotal</td>
            <td class="px-5 py-3 text-right text-sm font-medium text-gray-900 dark:text-white">R$ <%= number_with_precision(@sale.subtotal, precision: 2) %></td>
          </tr>
          <% if @sale.discount_amount.to_f > 0 %>
            <tr>
              <td colspan="3" class="px-5 py-3 text-right text-sm text-red-500">Desconto</td>
              <td class="px-5 py-3 text-right text-sm text-red-500">- R$ <%= number_with_precision(@sale.discount_amount, precision: 2) %></td>
            </tr>
          <% end %>
          <tr>
            <td colspan="3" class="px-5 py-3 text-right text-base font-bold text-gray-900 dark:text-white">Total</td>
            <td class="px-5 py-3 text-right text-xl font-bold text-green-600 dark:text-green-400">R$ <%= number_with_precision(@sale.total, precision: 2) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Info sidebar -->
  <div class="space-y-6">
    <!-- Status -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Informações</h3>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Status</dt>
          <dd><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= sale_status_badge(@sale.status) %>"><%= t("sale_statuses.#{@sale.status}") %></span></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Tipo</dt>
          <dd class="font-medium text-gray-900 dark:text-white"><%= @sale.quote? ? "Orçamento" : "Venda" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Pagamento</dt>
          <dd class="font-medium text-gray-900 dark:text-white"><%= t("payment_methods.#{@sale.payment_method}", default: "-") %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Vendedor</dt>
          <dd class="font-medium text-gray-900 dark:text-white"><%= @sale.user.name %></dd>
        </div>
      </dl>
    </div>

    <!-- Customer -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-3">Cliente</h3>
      <% if @sale.customer %>
        <p class="text-sm font-medium text-gray-900 dark:text-white"><%= @sale.customer.name %></p>
        <p class="text-xs text-gray-500 dark:text-gray-400"><%= @sale.customer.phone %></p>
        <%= link_to customer_path(@sale.customer), class: "text-xs text-blue-600 hover:text-blue-700 mt-1 block" do %>
          Ver cliente →
        <% end %>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400">Cliente avulso</p>
      <% end %>
    </div>

    <% if @sale.notes.present? %>
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
        <h3 class="font-semibold text-gray-900 dark:text-white mb-3">Observações</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400"><%= @sale.notes %></p>
      </div>
    <% end %>

    <% if @sale.pending? && policy(@sale).cancel? %>
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-red-200 dark:border-red-800 p-5">
        <h3 class="font-semibold text-red-700 dark:text-red-400 mb-3">Cancelar Venda</h3>
        <%= button_to cancel_sale_path(@sale), method: :patch, class: "w-full py-2 text-sm text-red-600 border border-red-300 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors", data: { turbo_confirm: "Tem certeza que deseja cancelar esta venda?" } do %>
          Cancelar Venda
        <% end %>
      </div>
    <% end %>
  </div>
</div>
