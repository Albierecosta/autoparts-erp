<div class="max-w-md mx-auto p-4 font-mono text-sm">
  <div class="text-center mb-4">
    <h1 class="text-lg font-bold"><%= current_company.name %></h1>
    <% if current_company.address.present? %>
      <p class="text-xs text-gray-600"><%= current_company.address %></p>
    <% end %>
    <% if current_company.phone.present? %>
      <p class="text-xs text-gray-600">Fone: <%= current_company.phone %></p>
    <% end %>
  </div>

  <div class="border-t-2 border-b-2 border-dashed border-gray-400 py-2 mb-3">
    <p class="text-center text-xs text-gray-600">
      <%= @sale.quote? ? "ORÇAMENTO" : "PEDIDO DE VENDA" %> N° <%= @sale.number %>
    </p>
    <p class="text-center text-xs text-gray-500"><%= @sale.created_at.strftime("%d/%m/%Y %H:%M") %></p>
  </div>

  <% if @sale.customer %>
    <div class="mb-3">
      <p class="text-xs text-gray-600">Cliente: <strong><%= @sale.customer.name %></strong></p>
      <% if @sale.customer.phone.present? %>
        <p class="text-xs text-gray-600">Tel: <%= @sale.customer.phone %></p>
      <% end %>
    </div>
  <% end %>

  <table class="w-full text-xs mb-3">
    <thead>
      <tr class="border-b border-dashed border-gray-400">
        <th class="text-left py-1">Produto</th>
        <th class="text-center py-1">Qtd</th>
        <th class="text-right py-1">Unit.</th>
        <th class="text-right py-1">Total</th>
      </tr>
    </thead>
    <tbody>
      <% @sale.sale_items.each do |item| %>
        <tr class="border-b border-dotted border-gray-200">
          <td class="py-1"><%= item.product_name %></td>
          <td class="text-center py-1"><%= item.quantity %></td>
          <td class="text-right py-1">R$ <%= number_with_precision(item.unit_price, precision: 2) %></td>
          <td class="text-right py-1">R$ <%= number_with_precision(item.total, precision: 2) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="border-t-2 border-dashed border-gray-400 pt-2 space-y-1">
    <div class="flex justify-between text-xs">
      <span>Subtotal:</span>
      <span>R$ <%= number_with_precision(@sale.subtotal, precision: 2) %></span>
    </div>
    <% if @sale.discount_amount.to_f > 0 %>
      <div class="flex justify-between text-xs text-red-600">
        <span>Desconto:</span>
        <span>- R$ <%= number_with_precision(@sale.discount_amount, precision: 2) %></span>
      </div>
    <% end %>
    <div class="flex justify-between font-bold text-sm border-t border-dashed border-gray-400 pt-1">
      <span>TOTAL:</span>
      <span>R$ <%= number_with_precision(@sale.total, precision: 2) %></span>
    </div>
    <% if @sale.payment_method.present? %>
      <div class="flex justify-between text-xs">
        <span>Pagamento:</span>
        <span><%= t("payment_methods.#{@sale.payment_method}") %></span>
      </div>
    <% end %>
  </div>

  <div class="border-t-2 border-dashed border-gray-400 mt-3 pt-2 text-center">
    <p class="text-xs text-gray-500">Vendedor: <%= @sale.user.name %></p>
    <% if current_company.settings["receipt_footer"].present? %>
      <p class="text-xs text-gray-500 mt-2"><%= current_company.settings["receipt_footer"] %></p>
    <% else %>
      <p class="text-xs text-gray-500 mt-2">Obrigado pela preferência!</p>
    <% end %>
  </div>
</div>
