<%= form_with model: [sale], class: "space-y-4", data: { controller: "sale-form", turbo: false } do |f| %>
  <% if sale.errors.any? %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% sale.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <!-- Items panel -->
    <div class="lg:col-span-2 space-y-4">
      <!-- Product search -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Buscar Produto</h3>
        <div class="flex gap-2" data-controller="product-search-sale">
          <div class="relative flex-1">
            <input type="text"
              placeholder="Código, nome, marca ou veículo..."
              class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
              data-product-search-sale-target="query"
              data-action="input->product-search-sale#search keydown->product-search-sale#handleKey"
              autocomplete="off">
            <div class="absolute top-full left-0 right-0 mt-1 bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 z-50 hidden max-h-64 overflow-y-auto"
                 data-product-search-sale-target="results">
            </div>
          </div>
        </div>
      </div>

      <!-- Items table -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Itens da Venda</h3>
          <span class="text-xs text-gray-500 dark:text-gray-400" data-sale-form-target="itemCount">0 item(s)</span>
        </div>

        <div id="sale-items" data-sale-form-target="itemsContainer">
          <%# items rendered dynamically via sale_form_controller.js %>
          <% sale.sale_items.each do |item| %>
            <% next if item.product_id.blank? %>
            <%= f.fields_for :sale_items, item do |item_f| %>
              <%= render "sale_item_fields", f: item_f %>
            <% end %>
          <% end %>
        </div>

        <div class="px-4 py-3 border-t border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-700/30" id="empty-items-msg" data-sale-form-target="emptyMsg">
          <p class="text-sm text-gray-400 text-center">Adicione produtos à venda</p>
        </div>

        <%= tag.template id: "sale-item-template" do %>
          <%= f.fields_for :sale_items, SaleItem.new, child_index: "ITEM_INDEX" do |item_f| %>
            <%= render "sale_item_fields", f: item_f %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Summary panel -->
    <div class="space-y-4">
      <!-- Customer -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Cliente</h3>
        <div data-controller="customer-search">
          <input type="text"
            placeholder="Buscar cliente..."
            class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 mb-2"
            data-customer-search-target="query"
            data-action="input->customer-search#search">
          <%= f.select :customer_id, options_from_collection_for_select(@customers, :id, :name, sale.customer_id),
              { include_blank: "Venda sem cliente" },
              class: "w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500",
              id: "sale_customer_id" %>
        </div>
      </div>

      <!-- Payment -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Pagamento</h3>
        <div class="space-y-3">
          <div>
            <%= f.label :payment_method, "Forma de Pagamento", class: "block text-xs text-gray-500 dark:text-gray-400 mb-1" %>
            <%= f.select :payment_method, options_for_select([
                ["Selecione...", ""],
                ["Dinheiro", "cash"],
                ["Cartão de Crédito", "credit_card"],
                ["Cartão de Débito", "debit_card"],
                ["PIX", "pix"],
                ["Transferência", "bank_transfer"],
                ["Outro", "other"]
              ], sale.payment_method),
              {},
              class: "w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
          </div>
          <div>
            <%= f.label :discount_percent, "Desconto (%)", class: "block text-xs text-gray-500 dark:text-gray-400 mb-1" %>
            <%= f.number_field :discount_percent, step: 0.5, min: 0, max: 100,
                class: "w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500",
                data: { "sale-form-target": "discountPercent", action: "input->sale-form#recalculate" } %>
          </div>
          <div>
            <%= f.label :discount_amount, "Desconto (R$)", class: "block text-xs text-gray-500 dark:text-gray-400 mb-1" %>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-500 text-sm">R$</span>
              <%= f.number_field :discount_amount, step: 0.01, min: 0,
                  class: "w-full pl-9 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500",
                  data: { "sale-form-target": "discountAmount", action: "input->sale-form#recalculate" } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Totals -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <div class="space-y-2 text-sm">
          <div class="flex justify-between text-gray-600 dark:text-gray-400">
            <span>Subtotal</span>
            <span data-sale-form-target="subtotal">R$ 0,00</span>
          </div>
          <div class="flex justify-between text-red-600 dark:text-red-400">
            <span>Desconto</span>
            <span data-sale-form-target="discount">- R$ 0,00</span>
          </div>
          <div class="flex justify-between font-bold text-lg text-gray-900 dark:text-white border-t border-gray-200 dark:border-gray-700 pt-2">
            <span>Total</span>
            <span data-sale-form-target="total">R$ 0,00</span>
          </div>
        </div>
      </div>

      <!-- Notes -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4">
        <%= f.label :notes, "Observações", class: "block text-xs text-gray-500 dark:text-gray-400 mb-1" %>
        <%= f.text_area :notes, rows: 2, class: "w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none" %>
      </div>

      <!-- Actions -->
      <div class="space-y-2">
        <%= f.hidden_field :sale_type, value: sale.sale_type %>
        <%= f.hidden_field :status, value: "confirmed", data: { "sale-form-target": "statusField" } %>

        <%= f.submit "Confirmar Venda", class: "w-full py-3 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg transition-colors cursor-pointer" %>

        <button type="button" class="w-full py-2.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg transition-colors text-sm"
          data-action="click->sale-form#saveAsPending">
          Salvar como Pendente
        </button>

        <%= link_to "Cancelar", sales_path, class: "block text-center w-full py-2 text-sm text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
      </div>
    </div>
  </div>
<% end %>
