<% content_for :title, "Fornecedores" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Fornecedores</h1>
  <%= link_to new_supplier_path, class: "flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Novo Fornecedor
  <% end %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 mb-6">
  <%= form_with url: suppliers_path, method: :get, class: "flex gap-3" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Buscar por nome ou CNPJ...",
        class: "flex-1 px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    <%= f.submit "Buscar", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg cursor-pointer" %>
  <% end %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
  <% if @suppliers.empty? %>
    <div class="p-12 text-center">
      <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Nenhum fornecedor encontrado</h3>
      <%= link_to new_supplier_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg mt-2" do %>Cadastrar Fornecedor<% end %>
    </div>
  <% else %>
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-700/50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Nome</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase hidden sm:table-cell">CNPJ</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase hidden md:table-cell">Contato</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @suppliers.each do |s| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
            <td class="px-4 py-3">
              <p class="text-sm font-medium text-gray-900 dark:text-white"><%= s.trade_name.presence || s.name %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= s.name %></p>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300 font-mono hidden sm:table-cell"><%= s.cnpj || "-" %></td>
            <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300 hidden md:table-cell"><%= s.phone || s.email || "-" %></td>
            <td class="px-4 py-3 text-center">
              <div class="flex items-center justify-center gap-2">
                <%= link_to supplier_path(s), class: "p-1.5 text-gray-400 hover:text-blue-600 rounded transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <% end %>
                <%= link_to edit_supplier_path(s), class: "p-1.5 text-gray-400 hover:text-yellow-600 rounded transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="px-4 py-3 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <p class="text-sm text-gray-500 dark:text-gray-400"><%= @pagy.count %> fornecedor(es)</p>
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
