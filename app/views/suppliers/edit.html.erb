    <%= link_to "Fornecedores", suppliers_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %><span>/</span>
    <%= link_to @supplier.name, supplier_path(@supplier), class: "hover:text-gray-700 dark:hover:text-gray-200" %><span>/</span>
    <span class="text-gray-900 dark:text-white">Editar</span>
  </nav>
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Editar Fornecedor</h1>
</div>
<%= render "form", supplier: @supplier %>
