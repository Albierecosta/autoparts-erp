<% content_for :title, @product.name %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
      <%= link_to "Produtos", products_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %>
      <span>/</span>
      <span class="text-gray-900 dark:text-white"><%= @product.name %></span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @product.name %></h1>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to new_product_stock_movement_path(@product), class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
      </svg>
      Movimentar Estoque
    <% end %>
    <%= link_to edit_product_path(@product), class: "flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg" do %>
      Editar
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Product info card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex gap-6">
        <div class="w-24 h-24 bg-gray-100 dark:bg-gray-700 rounded-xl flex-shrink-0 flex items-center justify-center overflow-hidden">
          <% if @product.photos.attached? %>
            <%= image_tag @product.primary_photo.variant(resize_to_fill: [96, 96]), class: "w-full h-full object-cover" %>
          <% else %>
            <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          <% end %>
        </div>
        <div class="flex-1">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white"><%= @product.name %></h2>
              <p class="text-sm text-gray-500 dark:text-gray-400"><%= @product.brand %></p>
            </div>
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium <%= @product.active? ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600" %>">
              <%= @product.active? ? "Ativo" : "Inativo" %>
            </span>
          </div>
          <div class="mt-3 grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
            <div>
              <p class="text-gray-500 dark:text-gray-400">Código</p>
              <p class="font-mono font-medium text-gray-900 dark:text-white"><%= @product.internal_code || "-" %></p>
            </div>
            <div>
              <p class="text-gray-500 dark:text-gray-400">SKU</p>
              <p class="font-mono font-medium text-gray-900 dark:text-white"><%= @product.sku || "-" %></p>
            </div>
            <div>
              <p class="text-gray-500 dark:text-gray-400">Categoria</p>
              <p class="font-medium text-gray-900 dark:text-white"><%= @product.category&.name || "-" %></p>
            </div>
          </div>
        </div>
      </div>
      <% if @product.description.present? %>
        <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700">
          <p class="text-sm text-gray-600 dark:text-gray-400"><%= @product.description %></p>
        </div>
      <% end %>
    </div>

    <!-- Vehicle applications -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Compatibilidade de Veículos</h3>
      <% if @product.vehicle_applications.any? %>
        <div class="space-y-2">
          <% @product.vehicle_applications.includes(:vehicle_make, :vehicle_model).each do |app| %>
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700 last:border-0">
              <span class="text-sm text-gray-700 dark:text-gray-300"><%= app.description %></span>
              <%= button_to product_vehicle_application_path(@product, app), method: :delete, class: "text-red-400 hover:text-red-600 p-1", data: { turbo_confirm: "Remover esta aplicação?" } do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400">Nenhuma compatibilidade cadastrada.</p>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Pricing -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Preços</h3>
      <div class="space-y-3">
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-500 dark:text-gray-400">Custo</span>
          <span class="text-sm font-medium text-gray-900 dark:text-white">R$ <%= number_with_precision(@product.cost_price, precision: 2) %></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-500 dark:text-gray-400">Venda</span>
          <span class="text-lg font-bold text-green-600 dark:text-green-400">R$ <%= number_with_precision(@product.sale_price, precision: 2) %></span>
        </div>
        <div class="flex justify-between items-center border-t border-gray-100 dark:border-gray-700 pt-3">
          <span class="text-sm text-gray-500 dark:text-gray-400">Margem</span>
          <span class="text-sm font-semibold text-blue-600 dark:text-blue-400"><%= @product.profit_margin %>%</span>
        </div>
      </div>
    </div>

    <!-- Stock -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Estoque</h3>
      <div class="text-center py-2">
        <p class="text-4xl font-bold <%= @product.out_of_stock? ? "text-red-600" : @product.low_stock? ? "text-orange-500" : "text-green-600" %>">
          <%= @product.stock_quantity %>
        </p>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1"><%= @product.stock_unit %></p>
      </div>
      <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700 space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-500 dark:text-gray-400">Mínimo</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @product.min_stock %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500 dark:text-gray-400">Máximo</span>
          <span class="font-medium text-gray-900 dark:text-white"><%= @product.max_stock || "-" %></span>
        </div>
      </div>
    </div>
  </div>
</div>
