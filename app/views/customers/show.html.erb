<% content_for :title, @customer.name %>

<div class="flex items-start justify-between mb-6">
  <div>
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
      <%= link_to "Clientes", customers_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %>
      <span>/</span>
      <span class="text-gray-900 dark:text-white"><%= @customer.name %></span>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @customer.name %></h1>
  </div>
  <div class="flex gap-3">
    <%= link_to new_sale_path(customer_id: @customer.id), class: "flex items-center gap-2 px-3 py-2 text-sm text-green-700 bg-green-50 border border-green-200 hover:bg-green-100 rounded-lg transition-colors" do %>
      + Nova Venda
    <% end %>
    <%= link_to edit_customer_path(@customer), class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg" do %>
      Editar
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Info -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-4">Dados</h2>
      <dl class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Documento</dt>
          <dd class="font-mono font-medium text-gray-900 dark:text-white mt-1"><%= @customer.document.presence || "-" %></dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Telefone</dt>
          <dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @customer.phone.presence || @customer.mobile.presence || "-" %></dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">E-mail</dt>
          <dd class="font-medium text-gray-900 dark:text-white mt-1"><%= @customer.email.presence || "-" %></dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Cidade</dt>
          <dd class="font-medium text-gray-900 dark:text-white mt-1"><%= [@customer.city, @customer.state].compact.join("/").presence || "-" %></dd>
        </div>
      </dl>
    </div>

    <!-- Veículos -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="font-semibold text-gray-900 dark:text-white mb-4">Veículos</h2>
      <% if @vehicles.any? %>
        <div class="space-y-2">
          <% @vehicles.each do |v| %>
            <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
              <div>
                <p class="text-sm font-medium text-gray-900 dark:text-white"><%= v.description %></p>
              </div>
              <%= button_to customer_vehicle_path(v), method: :delete, class: "text-red-400 hover:text-red-600 p-1 text-xs", data: { turbo_confirm: "Remover veículo?" } do %>
                Remover
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400">Nenhum veículo cadastrado.</p>
      <% end %>
    </div>

    <!-- Histórico de compras -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold text-gray-900 dark:text-white">Últimas Compras</h2>
        <%= link_to "Ver todas", sales_path(customer_id: @customer.id), class: "text-sm text-blue-600 hover:text-blue-700" %>
      </div>
      <% if @sales.any? %>
        <div class="space-y-2">
          <% @sales.each do |sale| %>
            <div class="flex items-center justify-between p-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded-lg">
              <div>
                <p class="text-sm font-medium text-gray-900 dark:text-white">Pedido #<%= sale.number %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400"><%= sale.created_at.strftime("%d/%m/%Y") %> · <%= sale.sale_items.count %> item(s)</p>
              </div>
              <p class="text-sm font-semibold text-green-600">R$ <%= number_with_precision(sale.total, precision: 2) %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400">Nenhuma compra registrada.</p>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Resumo</h3>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Total de compras</dt>
          <dd class="font-semibold text-gray-900 dark:text-white"><%= @customer.sales.confirmed.count %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Valor total</dt>
          <dd class="font-semibold text-green-600">R$ <%= number_with_precision(@customer.sales.confirmed.sum(:total), precision: 2) %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500 dark:text-gray-400">Status</dt>
          <dd><span class="px-2 py-0.5 rounded-full text-xs font-medium <%= @customer.active? ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600" %>"><%= @customer.active? ? "Ativo" : "Inativo" %></span></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
