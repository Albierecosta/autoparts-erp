<% content_for :title, "Editar #{@customer.name}" %>
<div class="mb-6">
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
    <%= link_to "Clientes", customers_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %>
    <span>/</span>
    <%= link_to @customer.name, customer_path(@customer), class: "hover:text-gray-700 dark:hover:text-gray-200" %>
    <span>/</span>
    <span class="text-gray-900 dark:text-white">Editar</span>
  </nav>
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Editar Cliente</h1>
</div>
<%= render "form", customer: @customer %>
