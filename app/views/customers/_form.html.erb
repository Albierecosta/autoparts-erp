<%= form_with model: [customer], class: "space-y-6", data: { controller: "customer-form" } do |f| %>
  <% if customer.errors.any? %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
      <ul class="text-sm text-red-700 list-disc list-inside space-y-1">
        <% customer.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <!-- Dados pessoais -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Dados do Cliente</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <%= f.label :name, "Nome *", class: "form-label" %>
            <%= f.text_field :name, class: "form-input", placeholder: "Nome completo ou razão social" %>
          </div>
          <div>
            <%= f.label :document_type, "Tipo de Documento", class: "form-label" %>
            <%= f.select :document_type,
                options_for_select([["CPF (Pessoa Física)", "cpf"], ["CNPJ (Pessoa Jurídica)", "cnpj"]], customer.document_type),
                {}, class: "form-input" %>
          </div>
          <div>
            <%= f.label :document, "CPF / CNPJ", class: "form-label" %>
            <%= f.text_field :document, class: "form-input font-mono", placeholder: "000.000.000-00" %>
          </div>
          <div>
            <%= f.label :phone, "Telefone", class: "form-label" %>
            <%= f.text_field :phone, class: "form-input", placeholder: "(11) 3000-0000" %>
          </div>
          <div>
            <%= f.label :mobile, "Celular", class: "form-label" %>
            <%= f.text_field :mobile, class: "form-input", placeholder: "(11) 99000-0000" %>
          </div>
          <div>
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email, class: "form-input", placeholder: "email@exemplo.com" %>
          </div>
          <div>
            <%= f.label :birthdate, "Data de Nascimento", class: "form-label" %>
            <%= f.date_field :birthdate, class: "form-input" %>
          </div>
        </div>
      </div>

      <!-- Endereço -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4">Endereço</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="sm:col-span-2">
            <%= f.label :address, "Logradouro", class: "form-label" %>
            <%= f.text_field :address, class: "form-input", placeholder: "Rua, número, complemento" %>
          </div>
          <div>
            <%= f.label :zip_code, "CEP", class: "form-label" %>
            <%= f.text_field :zip_code, class: "form-input font-mono", placeholder: "00000-000" %>
          </div>
          <div class="sm:col-span-2">
            <%= f.label :city, "Cidade", class: "form-label" %>
            <%= f.text_field :city, class: "form-input" %>
          </div>
          <div>
            <%= f.label :state, "Estado", class: "form-label" %>
            <%= f.text_field :state, maxlength: 2, class: "form-input", placeholder: "SP" %>
          </div>
        </div>
      </div>

      <!-- Observações -->
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
        <%= f.label :notes, "Observações", class: "form-label" %>
        <%= f.text_area :notes, rows: 3, class: "form-input resize-none" %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Status</h3>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :active, class: "w-4 h-4 rounded border-gray-300 text-blue-600" %>
          <span class="text-sm text-gray-700 dark:text-gray-300">Cliente ativo</span>
        </label>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancelar", customer.persisted? ? customer_path(customer) : customers_path,
        class: "px-4 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 transition-colors" %>
    <%= f.submit customer.persisted? ? "Salvar Alterações" : "Cadastrar Cliente",
        class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg cursor-pointer" %>
  </div>
<% end %>
