<!DOCTYPE html>
<html lang="pt-BR" class="h-full" id="html-root">
  <head>
    <title><%= content_for(:title).presence || "#{current_company&.name || "AutoPeças"} - ERP" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100" data-controller="app">
    <% if user_signed_in? %>
      <div class="flex h-full" id="app-wrapper">
        <%= render "shared/sidebar" %>
        <div class="flex flex-col flex-1 overflow-hidden lg:pl-64">
          <%= render "shared/topbar" %>
          <main class="flex-1 overflow-y-auto focus:outline-none">
            <div class="py-6 px-4 sm:px-6 lg:px-8">
              <%= render "shared/flash" %>
              <%= yield %>
            </div>
          </main>
        </div>
      </div>
    <% else %>
      <div class="min-h-full">
        <%= render "shared/flash" %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
