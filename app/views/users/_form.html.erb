<%= form_with model: [user], class: "space-y-6" do |f| %>
  <% if user.errors.any? %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
      <ul class="text-sm text-red-700 list-disc list-inside"><% user.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="max-w-lg bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5 space-y-4">
    <div>
      <%= f.label :name, "Nome *", class: "form-label" %>
      <%= f.text_field :name, class: "form-input", placeholder: "Nome completo" %>
    </div>
    <div>
      <%= f.label :email, "E-mail *", class: "form-label" %>
      <%= f.email_field :email, class: "form-input", placeholder: "email@exemplo.com" %>
    </div>
    <div>
      <%= f.label :role, "Perfil *", class: "form-label" %>
      <%= f.select :role, options_for_select([
          ["Administrador", "admin"], ["Gerente", "manager"], ["Operador", "operator"]
        ], user.role), {}, class: "form-input" %>
    </div>
    <div>
      <%= f.label :password, user.persisted? ? "Nova Senha (deixe em branco para manter)" : "Senha *", class: "form-label" %>
      <%= f.password_field :password, class: "form-input", autocomplete: "new-password", placeholder: "Mínimo 6 caracteres" %>
    </div>
    <div>
      <%= f.label :password_confirmation, "Confirmar Senha", class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-input", autocomplete: "new-password" %>
    </div>
    <label class="flex items-center gap-3 cursor-pointer">
      <%= f.check_box :active, class: "w-4 h-4 rounded border-gray-300 text-blue-600" %>
      <span class="text-sm text-gray-700 dark:text-gray-300">Usuário ativo</span>
    </label>
  </div>

  <div class="flex items-center justify-end gap-3 max-w-lg">
    <%= link_to "Cancelar", users_path, class: "px-4 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 transition-colors" %>
    <%= f.submit user.persisted? ? "Salvar Alterações" : "Criar Usuário", class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg cursor-pointer" %>
  </div>
<% end %>
